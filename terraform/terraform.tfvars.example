aws_region   = "ap-northeast-1"
project_name = "firelens-verify"

# Existing VPC and subnets (subnets are supplied when running tasks via aws ecs run-task)
vpc_id = "vpc-xxxxxxxxxxxxxxxxx"

# Must be globally unique — used to form: firelens-verify-logs-<suffix>
s3_bucket_suffix = "REPLACE_ME"

# Retention is intentionally short to keep costs low during verification
app_log_retention_days        = 1
log_router_retention_days     = 1

task_cpu    = "256"
task_memory = "512"

# 検証2 用。app の awsfirelens ドライバが Fluent Bit へ渡す前に保持するログ行数（Docker→FB 間）。
# AWS 既定は 1048576 行。検証2 では次の2点を満たす値にする:
#   - overlimit を出すため 50MB 相当（10KB 行で約 5,120 行）より大きく
#     （小さすぎると Docker 段で先に破棄され、FB が 50MB に達せず overlimit が出ない）
#   - 欠落を出すため N×10KB が (50MB + 本値×10KB) を十分超えるよう N を設定する
#     （大きすぎると破棄されず欠落しない）
# 検証2・検証3 とも同じ値で実行して比較する（差は enable_filesystem_buffer のみ）。
app_log_driver_buffer_limit = 8192

# 検証3 用トグル。true = filesystem バッファ構成（:fs イメージ + フル設定 CMD）
#                  false = memory バッファ + extra.conf @INCLUDE 方式（既定）
enable_filesystem_buffer = false